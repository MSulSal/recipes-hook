# LocalWP and machine-specific files
/conf/
/logs/
/app/sql/
/app/public/local-xdebuginfo.php

# WordPress core
/app/public/wp-admin/
/app/public/wp-includes/
/app/public/index.php
/app/public/license.txt
/app/public/readme.html
/app/public/wp-*.php
/app/public/xmlrpc.php
/app/public/.htaccess
/app/public/wp-config.php
/app/public/wp-config-sample.php

# WordPress content that should not be committed
/app/public/wp-content/uploads/
/app/public/wp-content/cache/
/app/public/wp-content/upgrade/
/app/public/wp-content/debug.log
/app/public/wp-content/index.php

# Third-party/default plugins and themes
/app/public/wp-content/plugins/*
!/app/public/wp-content/plugins/recipe-pdf-library/
/app/public/wp-content/themes/*

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
